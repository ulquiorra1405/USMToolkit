<UserControl x:Class="Toolkit.Views.CommandsEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:Toolkit.Models"
              Background="{DynamicResource ContentBgBrush}">
    <UserControl.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#F5A623" />

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource SidebarBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="0">
                            <ItemsPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource SidebarBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TextDimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="8 5" />
            <Setter Property="HasDropShadow" Value="True" />
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12 8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4" Margin="2 1"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A2A" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TextDimBrush}" />
                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
                                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveAllCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
    </UserControl.InputBindings>
    <Grid Margin="8 8 8 28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Column 1: TreeView -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Background="Transparent">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="CATEGORÍAS" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="4 0 0 8" />

                <TextBox Grid.Row="1" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Buscar..."
                         materialDesign:HintAssist.Foreground="{DynamicResource HintTextBrush}"
                         materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource AccentBrush}"
                         materialDesign:TextFieldAssist.CharacterCounterVisibility="Hidden"
                         Background="{DynamicResource DarkCardBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                         FontSize="12" Margin="4 0 4 8" />

                <TreeView Grid.Row="2" x:Name="MainTree"
                          ItemsSource="{Binding Categorias}"
                          SelectedItemChanged="OnTreeSelectedItemChanged"
                          PreviewMouseRightButtonDown="OnTreePreviewRightClick"
                          Background="Transparent" BorderThickness="0">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Style.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1E1E1E" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F5A623" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#1E1E1E" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#F5A623" />
                            </Style.Resources>
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="Padding" Value="4 3" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="ContextMenu" Value="{x:Null}" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
                                    <Setter Property="BorderThickness" Value="3,0,0,0" />
                                    <Setter Property="BorderBrush" Value="#F5A623" />
                                    <Setter Property="Foreground" Value="#F5A623" />
                                    <Setter Property="Padding" Value="4 3" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.Resources>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type models:CategoriaItem}"
                                                  ItemsSource="{Binding Items}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="{Binding Icono, Converter={StaticResource StringToIcon}}"
                                                         Width="16" Height="16" Foreground="#F5A623" Margin="0 0 6 0" />
                                <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Items.Count, StringFormat='  ({0})'}"
                                           FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="4 0 0 0" VerticalAlignment="Center" />
                            </StackPanel>
                            <HierarchicalDataTemplate.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ComandoItem}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Nombre}" Foreground="#CCC" />
                                    </StackPanel>
                                </DataTemplate>
                            </HierarchicalDataTemplate.ItemTemplate>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <WrapPanel Grid.Row="3" Margin="0 8 0 0"
                           IsEnabled="{Binding IsEditorEnabled}">
                    <Button Command="{Binding MoveItemUpCommand}"
                            Background="{DynamicResource SidebarBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource TextMutedBrush}"
                            BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="4"
                            Padding="4 2" MinWidth="28" Height="28" FontSize="14" Cursor="Hand"
                            Content="▲" />
                    <Button Command="{Binding MoveItemDownCommand}"
                            Background="{DynamicResource SidebarBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource TextMutedBrush}"
                            BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="4"
                            Padding="4 2" MinWidth="28" Height="28" FontSize="14" Cursor="Hand"
                            Margin="4 0 0 0"
                            Content="▼" />
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Column 2: Splitter -->
        <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}" Width="1" HorizontalAlignment="Center" />

        <!-- Column 3: Editor -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Margin="8 0 0 0">
            <StackPanel Margin="0 0 8 0">
                <!-- Category card -->
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8"
                        Background="{DynamicResource DarkCardBgBrush}" Padding="16" Margin="0 0 0 16"
                        IsEnabled="{Binding IsCategoriaEditable}"
                        x:Name="CategoryCard"
                        Visibility="{Binding IsCategoryPanelVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                            <Button x:Name="IconPickerBtn" Click="ToggleIconPicker"
                                    Background="{DynamicResource SidebarBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Cursor="Hand" Padding="4" Width="28" Height="28"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    ToolTip="Seleccionar icono">
                                <materialDesign:PackIcon Kind="{Binding EditCategoriaIcono, Converter={StaticResource StringToIcon}}"
                                                         Width="16" Height="16" Foreground="#F5A623" />
                            </Button>
                            <TextBlock Text="CATEGORÍA" FontSize="11" Foreground="#F5A623"
                                       VerticalAlignment="Center" Margin="8 0 0 0" />
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding EditCategoriaNombre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Nombre"
                                     materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource AccentBrush}"
                                     materialDesign:TextFieldAssist.CharacterCounterVisibility="Hidden"
                                     Background="{DynamicResource DarkCardBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontSize="13" />
                            <ComboBox Grid.Column="2" ItemsSource="{Binding TiposDisponibles}" SelectedItem="{Binding EditCategoriaTipo}"
                                      materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource AccentBrush}"
                                      Background="{DynamicResource DarkCardBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                      FontSize="12" />
                        </Grid>

                        <TextBox Text="{Binding EditCategoriaDescripcion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Descripción"
                                 materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource AccentBrush}"
                                 materialDesign:TextFieldAssist.CharacterCounterVisibility="Hidden"
                                 Background="{DynamicResource DarkCardBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 FontSize="12" Margin="0 8 0 0" />
                    </StackPanel>
                </Border>

                <Popup x:Name="IconPickerPopup" PlacementTarget="{Binding ElementName=IconPickerBtn}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8">
                        <StackPanel>
                            <TextBox Text="{Binding IconSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Buscar icono..."
                                     materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource AccentBrush}"
                                     materialDesign:TextFieldAssist.CharacterCounterVisibility="Hidden"
                                     Background="{DynamicResource DarkCardBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0 0 0 8" />
                            <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FilteredIconos}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel MaxWidth="336" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Width="36" Height="36" Padding="0" Margin="2"
                                                    Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                                                    Command="{Binding DataContext.SelectIconCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="{Binding Converter={StaticResource StringToIcon}}"
                                                                         Width="20" Height="20" Foreground="#CCC" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Command section (command card + save/run + output) -->
                <StackPanel IsEnabled="{Binding IsEditorEnabled}"
                            Visibility="{Binding IsCommandPanelVisible, Converter={StaticResource BoolToVis}}">
                    <!-- Command card -->
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8"
                            Background="{DynamicResource DarkCardBgBrush}" Padding="16" Margin="0 0 0 16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                                <materialDesign:PackIcon Kind="CodeBraces" Width="16" Height="16" Foreground="#F5A623" Margin="0 0 8 0" />
                                <TextBlock Text="COMANDO" FontSize="11" Foreground="#F5A623"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBox Text="{Binding EditNombre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Nombre"
                                     materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource AccentBrush}"
                                     materialDesign:TextFieldAssist.CharacterCounterVisibility="Hidden"
                                     Background="{DynamicResource DarkCardBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontSize="13" />

                            <TextBox Text="{Binding EditDescripcion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Descripción"
                                     materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource AccentBrush}"
                                     materialDesign:TextFieldAssist.CharacterCounterVisibility="Hidden"
                                     Background="{DynamicResource DarkCardBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontSize="12" />

                            <CheckBox IsChecked="{Binding EditAdmin}" Content="Ejecutar como administrador"
                                      Foreground="#AAA" FontSize="12" Margin="0 14 0 0" />
                            <CheckBox IsChecked="{Binding EditRequireConfirm}" Content="Confirmar antes de ejecutar"
                                      Foreground="#F5A623" FontSize="12" Margin="0 6 0 0" />

                            <WrapPanel Margin="0 12 0 0">
                                <TextBlock Text="Shell:" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                                           VerticalAlignment="Center" Margin="0 0 8 0" />
                                <ComboBox ItemsSource="{Binding ShellsDisponibles}" SelectedItem="{Binding EditShell}"
                                          Background="{DynamicResource DarkCardBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                          FontSize="12" MinWidth="100" />
                            </WrapPanel>

                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8"
                                    Background="{DynamicResource DarkCardBgBrush}" Padding="14" Margin="0 12 0 0">
                                <StackPanel>
                                    <!-- Header -->
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                        <materialDesign:PackIcon Kind="CodeBraces" Width="14" Height="14" Foreground="#F5A623"
                                                                 VerticalAlignment="Center" Margin="0 0 6 0" />
                                        <TextBlock Text="VARIABLES" FontSize="10" Foreground="#F5A623"
                                                   VerticalAlignment="Center" />
                                        <Button Command="{Binding AddVariableCommand}"
                                                Background="{DynamicResource SidebarBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                BorderBrush="{DynamicResource TextMutedBrush}" BorderThickness="1"
                                                materialDesign:ButtonAssist.CornerRadius="4"
                                                Padding="8 2" MinWidth="26" Height="22" FontSize="12" Cursor="Hand"
                                                Margin="10 0 0 0">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Plus" Width="12" Height="12"
                                                                         Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <!-- Column headers -->
                                    <Grid Margin="0 0 0 4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="NOMBRE" FontSize="9"
                                                   Foreground="{DynamicResource TextDimBrush}" />
                                        <TextBlock Grid.Column="2" Text="ETIQUETA" FontSize="9"
                                                   Foreground="{DynamicResource TextDimBrush}" />
                                        <TextBlock Grid.Column="4" Text="DEFAULT" FontSize="9"
                                                   Foreground="{DynamicResource TextDimBrush}" />
                                    </Grid>

                                    <!-- Variable rows -->
                                    <ItemsControl ItemsSource="{Binding EditVariables}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                                        Padding="0 4 0 4">
                                                    <Grid VerticalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="90" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="80" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="80" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="30" />
                                                            <ColumnDefinition Width="30" />
                                                            <ColumnDefinition Width="30" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                 materialDesign:HintAssist.Hint="{}{{nombre}}"
                                                                 materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource AccentBrush}"
                                                                 materialDesign:TextFieldAssist.CharacterCounterVisibility="Hidden"
                                                                 Background="{DynamicResource DarkCardBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                                 FontFamily="Consolas" FontSize="11" MaxHeight="26" />
                                                        <TextBox Grid.Column="2" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                                 materialDesign:HintAssist.Hint="Etiqueta"
                                                                 materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource AccentBrush}"
                                                                 materialDesign:TextFieldAssist.CharacterCounterVisibility="Hidden"
                                                                 Background="{DynamicResource DarkCardBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                                 FontSize="11" MaxHeight="26" />
                                                        <TextBox Grid.Column="4" Text="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}"
                                                                 materialDesign:HintAssist.Hint="Valor"
                                                                 materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource AccentBrush}"
                                                                 materialDesign:TextFieldAssist.CharacterCounterVisibility="Hidden"
                                                                 Background="{DynamicResource DarkCardBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                                 FontSize="11" MaxHeight="26" />
                                                        <ToggleButton Grid.Column="6"
                                                                      IsChecked="{Binding Sensitive}"
                                                                      ToolTip="Campo sensible (contraseña)"
                                                                      Cursor="Hand" Padding="0" Width="28" Height="28">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border CornerRadius="4" Width="28" Height="28">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="Transparent" />
                                                                                <Style.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <Grid Width="14" Height="14">
                                                                            <materialDesign:PackIcon Kind="LockOutline" Width="14" Height="14"
                                                                                     Foreground="{DynamicResource TextMutedBrush}"
                                                                                     Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}, Converter={StaticResource BoolInvert}}" />
                                                                            <materialDesign:PackIcon Kind="Lock" Width="14" Height="14"
                                                                                     Foreground="#F5A623"
                                                                                     Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}, Converter={StaticResource BoolToVis}}" />
                                                                        </Grid>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>
                                                        <ToggleButton Grid.Column="7"
                                                                      IsChecked="{Binding Required}"
                                                                      ToolTip="Campo requerido"
                                                                      Cursor="Hand" Padding="0" Width="28" Height="28">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border CornerRadius="4" Width="28" Height="28">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="Transparent" />
                                                                                <Style.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <Grid Width="14" Height="14">
                                                                            <materialDesign:PackIcon Kind="AlertOutline" Width="14" Height="14"
                                                                                     Foreground="{DynamicResource TextMutedBrush}"
                                                                                     Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}, Converter={StaticResource BoolInvert}}" />
                                                                            <materialDesign:PackIcon Kind="Alert" Width="14" Height="14"
                                                                                     Foreground="#F5A623"
                                                                                     Visibility="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}, Converter={StaticResource BoolToVis}}" />
                                                                        </Grid>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>
                                                        <Button Grid.Column="8"
                                                                Command="{Binding DataContext.RemoveVariableCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Cursor="Hand" Padding="0" Width="28" Height="28">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border CornerRadius="4" Width="28" Height="28">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="Transparent" />
                                                                                <Style.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14"
                                                                                                 Foreground="#F5A623"
                                                                                                 HorizontalAlignment="Center"
                                                                                                 VerticalAlignment="Center" />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <TextBox Text="{Binding EditPasosText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource AccentBrush}"
                                     materialDesign:TextFieldAssist.CharacterCounterVisibility="Hidden"
                                     Background="{DynamicResource DarkCardBgBrush}" Foreground="{DynamicResource TextSecondaryBrush}"
                                     FontFamily="Consolas" FontSize="12"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="8 6" MinHeight="160"
                                     VerticalContentAlignment="Top">
                                <materialDesign:HintAssist.Hint>
                                    <TextBlock FontFamily="Consolas" FontSize="12">
                                        command /s<LineBreak/>command /s<LineBreak/>command /s
                                    </TextBlock>
                                </materialDesign:HintAssist.Hint>
                            </TextBox>
                        </StackPanel>
                    </Border>

                    <!-- Save / Run -->
                    <StackPanel Orientation="Horizontal" Margin="0 4 0 12">
                        <Button Content="💾 Guardar" Command="{Binding SaveAllCommand}"
                                Style="{StaticResource OutlinedAccentButton}"
                                HorizontalAlignment="Left">
                            <Button.ToolTip>
                                <ToolTip Content="Ctrl+S" />
                            </Button.ToolTip>
                        </Button>
                        <Button Content="▶ Ejecutar" Command="{Binding ExecuteSelectedCommand}"
                                IsEnabled="{Binding IsRunning, Converter={StaticResource BoolInvert}}"
                                Background="{DynamicResource SidebarBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource TextMutedBrush}"
                                BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="4"
                                Padding="14 7" FontSize="12" Cursor="Hand" MaxHeight="30"
                                Margin="8 0 0 0" ToolTip="Ejecuta los pasos del comando seleccionado" />
                    </StackPanel>

                    <!-- Run output -->
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                            Background="{DynamicResource DarkCardBgBrush}" Padding="8"
                            Visibility="{Binding HasRunOutput, Converter={StaticResource BoolToVis}}">
                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding RunOutput}" FontFamily="Consolas" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
