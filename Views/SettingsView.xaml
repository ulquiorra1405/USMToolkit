<UserControl x:Class="Toolkit.Views.SettingsView"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:Toolkit.Models"
             Background="{DynamicResource ContentBgBrush}">
    <ScrollViewer Padding="20 20 20 20" Background="Transparent"
                   HorizontalScrollBarVisibility="Disabled"
                   VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- Toolkit configuration -->
            <TextBlock Text="Toolkit" FontSize="24" FontWeight="Light" Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Configuración del Toolkit" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0 4 0 20" />

            <Border Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="14" Margin="0 0 20 8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Ruta de red"
                               FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0 0 0 8" />
                    <TextBox Grid.Row="1" Grid.Column="0"
                             Text="{Binding ToolkitNetworkPath, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="\\server\share\Toolkit"
                             materialDesign:TextFieldAssist.HasFilledTextField="True"
                             Foreground="#CCC" FontSize="13"
                             Padding="8 6" BorderThickness="0" VerticalAlignment="Center"
                             Background="{DynamicResource CardBgBrush}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                    <Button Grid.Row="1" Grid.Column="1" Content="📁"
                            Background="Transparent" Foreground="{DynamicResource TextMutedBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Cursor="Hand" Margin="8 0 0 0"
                            Width="32" Height="32"
                            materialDesign:ButtonAssist.CornerRadius="4" />

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0 12 0 0">
                        <TextBlock Text="Modo avanzado" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <ToggleButton IsChecked="{Binding ToolkitAdvancedMode}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      Margin="12 0 24 0" VerticalAlignment="Center" />
                        <TextBlock Text="Tema claro" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <ToggleButton IsChecked="{Binding ToolkitUseLightTheme}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      Margin="12 0 0 0" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Registry settings -->
            <TextBlock Text="Ajustes del sistema" FontSize="24" FontWeight="Light" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0 24 0 0" />
            <TextBlock Text="Configuración del sistema vía registro" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0 4 0 20" />

            <ItemsControl ItemsSource="{Binding Settings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:SettingItem">
                        <Border Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="14" Margin="0 0 20 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0 2 0 0" />
                                    <TextBlock Text="{Binding Category, StringFormat='[{0}]'}"
                                               FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 4 0 0" />
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding IsActive, Mode=TwoWay}"
                                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                              VerticalAlignment="Center"
                                              Command="{Binding ElementName=root, Path=DataContext.ToggleRegistryCommand}"
                                              CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="ACCIONES" FontSize="11" Foreground="{DynamicResource TextDimBrush}" Margin="24 20 0 12" />
            <Button Content="⟳ Reiniciar Explorador" Command="{Binding RestartExplorerCommand}"
Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="4" Padding="14 7" Margin="24 0 20 8" FontSize="12"
                    Cursor="Hand" HorizontalAlignment="Left" MaxHeight="30" />
            <Button Content="☰ Leer estado del registro" Command="{Binding ReadRegistrySettingsCommand}"
Background="Transparent" Foreground="{DynamicResource TextMutedBrush}" BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="4" Padding="14 7" Margin="24 0 20 20" FontSize="12"
                    Cursor="Hand" HorizontalAlignment="Left" MaxHeight="30" />

            <TextBlock Text="CONSOLA" FontSize="11" Foreground="{DynamicResource TextDimBrush}" Margin="24 0 0 12" />
            <Border Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                    Padding="12" MinHeight="150" Margin="24 0 20 20">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBlock Text="{Binding CmdOutput}" FontFamily="Consolas"
                               FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>