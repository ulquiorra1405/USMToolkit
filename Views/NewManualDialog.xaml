<Window x:Class="Toolkit.Views.NewManualDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Nuevo manual"
        Width="480"
        Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource ContentBgBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0 0 0 20">
            <TextBlock Text="📝 Nuevo manual" FontSize="22" FontWeight="Light" />
            <TextBlock Text="Completa los datos para crear un nuevo manual" FontSize="13"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="0 4 0 0" />
        </StackPanel>

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Título *" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0 0 0 4" />
            <TextBox x:Name="TitleBox"
                     materialDesign:HintAssist.Hint="Ej: VPN - Error de autenticación"
                     materialDesign:TextFieldAssist.HasFilledTextField="True"
                     Foreground="#CCC" FontSize="13"
                     Padding="8 6" BorderThickness="0"
                     Background="{DynamicResource CardBgBrush}"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     TextChanged="OnTitleChanged" />

            <TextBlock Text="Categoría *" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0 16 0 4" />
            <ComboBox x:Name="CategoryCombo"
                      materialDesign:TextFieldAssist.HasFilledTextField="True"
                      Foreground="#CCC" FontSize="13"
                      Padding="8 4" BorderThickness="0"
                      Background="{DynamicResource CardBgBrush}"
                      Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                <ComboBoxItem Tag="instalacion" IsSelected="True">📦 Instalación</ComboBoxItem>
                <ComboBoxItem Tag="resolucion">🔧 Resolución</ComboBoxItem>
            </ComboBox>

            <TextBlock Text="Tags (opcional)" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0 16 0 4" />
            <TextBox x:Name="TagsBox"
                     materialDesign:HintAssist.Hint="vpn, windows, conexion"
                     materialDesign:TextFieldAssist.HasFilledTextField="True"
                     Foreground="#CCC" FontSize="13"
                     Padding="8 6" BorderThickness="0"
                     Background="{DynamicResource CardBgBrush}"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
        </StackPanel>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 16 0 0">
            <Button Content="Cancelar" IsCancel="True"
                    Background="Transparent"
                    Foreground="{DynamicResource TextMutedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    Padding="16 8" Margin="0 0 8 0" FontSize="13"
                    Cursor="Hand" MinWidth="80" />
            <Button x:Name="CreateBtn" Content="Crear y editar" IsDefault="True"
                    Click="OnCreateClick"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    Padding="16 8" FontSize="13"
                    Cursor="Hand" MinWidth="120" IsEnabled="False" />
        </StackPanel>
    </Grid>
</Window>
