<UserControl x:Class="Toolkit.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:Toolkit.Controls"
             Background="{DynamicResource ContentBgBrush}">
    <UserControl.Resources>
        <Style x:Key="DashCard" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="4" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#F5A623" />
                    <Setter Property="Background" Value="{DynamicResource SidebarBgBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="UsageProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="3" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="#F5A623" />
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>

    <ScrollViewer Padding="32" Background="Transparent"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Light" Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Resumen del sistema" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0 4 0 0" />

            <controls:AdaptiveUniformGrid ItemMinWidth="220" Margin="0 24 0 0">
                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="⊞" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="SISTEMA" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding OsVersion}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding OsInstallDate}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0 4 0 0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="⏱" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="UPTIME" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding Uptime}" FontSize="22" FontWeight="SemiBold" Foreground="#F5A623" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="⚙" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="CPU" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding CpuInfo}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                        <WrapPanel Orientation="Horizontal" Margin="0 4 0 2">
                            <TextBlock Text="{Binding CpuUsagePercent, StringFormat='Uso: {0:F1}%'}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Text="  ·  " FontSize="11" Foreground="#444" />
                            <TextBlock Text="Temp: " FontSize="12" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Text="{Binding CpuTemp}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding CpuTempColor}" />
                        </WrapPanel>
                        <ProgressBar Value="{Binding CpuUsagePercent}" Style="{StaticResource UsageProgress}" Foreground="{Binding CpuUsageColor}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="🎮" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="GPU" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding GpuInfo}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                        <WrapPanel Orientation="Horizontal" Margin="0 4 0 2">
                            <TextBlock Text="{Binding GpuUsagePercent, StringFormat='Uso: {0:F1}%'}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Text="  ·  " FontSize="11" Foreground="#444" />
                            <TextBlock Text="Temp: " FontSize="12" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Text="{Binding GpuTemp}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding GpuTempColor}" />
                        </WrapPanel>
                        <ProgressBar Value="{Binding GpuUsagePercent}" Style="{StaticResource UsageProgress}" Foreground="{Binding GpuUsageColor}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="🖫" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="MEMORIA" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding MemoryUsage}" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding RamSpecs}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0 4 0 8" TextWrapping="Wrap" />
                        <ProgressBar Value="{Binding MemoryPercent}" Style="{StaticResource UsageProgress}" Foreground="{Binding MemoryUsageColor}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="💿" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="DISCO" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding DiskInfo}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                        <WrapPanel Orientation="Horizontal" Margin="0 4 0 0">
                            <TextBlock Text="Temp: " FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Text="{Binding DiskTemp}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </WrapPanel>
                        <TextBlock Text="{Binding DiskSmartInfo}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0 4 0 0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding Gesture="LeftClick" Command="{Binding RunSpeedTestCommand}" />
                    </Border.InputBindings>
                    <StackPanel>
                        <TextBlock Text="🌐" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="VELOCIDAD" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding NetworkInfo}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding NetworkTraffic}" FontSize="14" FontWeight="SemiBold" Foreground="#F5A623" Margin="0 8 0 0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="📶" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="PING" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 6 0 2" />
                        <WrapPanel Orientation="Horizontal">
                            <TextBlock Text="Puerta enlace: " FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Text="{Binding PingLatency, StringFormat='{}{0:F0} ms'}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding PingLatencyColor}" />
                            <TextBlock Text="  ·  " FontSize="11" Foreground="#444" />
                            <TextBlock Text="{Binding PingPacketLoss, StringFormat='{}{0:F0}% pérdida'}" FontSize="11" Foreground="{Binding PingLossColor}" />
                        </WrapPanel>
                        <WrapPanel Orientation="Horizontal" Margin="0 4 0 0">
                            <TextBlock Text="Google: " FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Text="{Binding PingGoogleLatency, StringFormat='{}{0:F0} ms'}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding PingGoogleLatencyColor}" />
                            <TextBlock Text="  ·  " FontSize="11" Foreground="#444" />
                            <TextBlock Text="{Binding PingGooglePacketLoss, StringFormat='{}{0:F0}% pérdida'}" FontSize="11" Foreground="{Binding PingGoogleLossColor}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="🔋" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="BATERÍA" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding BatteryInfo}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <ProgressBar Value="{Binding BatteryPercent}" Style="{StaticResource UsageProgress}"
                                     Foreground="#4CAF50" Margin="0 8 0 0"
                                     Visibility="{Binding HasBattery, Converter={StaticResource BoolVis}}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="🌀" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="VENTILADORES" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding FanSpeeds}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="🔧" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="PLACA BASE" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding MotherboardInfo}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="⚡" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="BIOS" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding BiosInfo}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding Gesture="LeftClick" Command="{Binding OpenWarrantyUrlCommand}" />
                    </Border.InputBindings>
                    <StackPanel>
                        <TextBlock Text="🛡" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="GARANTÍA" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding WarrantyInfo}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="🛡" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="WINDOWS DEFENDER" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding DefenderStatus}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="⚡" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="PLAN DE ENERGÍA" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding PowerPlan}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="🔔" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="ACTUALIZACIONES" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding PendingUpdates}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="⚠" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="ERRORES (24H)" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding RecentErrorCount}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding RecentCriticalCount}" FontSize="13" FontWeight="SemiBold" Foreground="#E53935" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashCard}">
                    <StackPanel>
                        <TextBlock Text="🔬" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="HEALTH SCORE" FontSize="10" Foreground="{DynamicResource TextDimBrush}" Margin="0 8 0 2" />
                        <TextBlock Text="{Binding HealthStatus}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding HealthScore, StringFormat='{}{0:F0}/100'}" FontSize="28" FontWeight="Bold" Foreground="{Binding HealthScoreColor}" />
                        <TextBlock Text="{Binding HealthBreakdown}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0 6 0 0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </controls:AdaptiveUniformGrid>

            <Border Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0 16 0 0" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Button Content="📄 Exportar diagnóstico"
                            Command="{Binding ExportDiagnosticCommand}"
                            Background="Transparent"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            materialDesign:ButtonAssist.CornerRadius="4"
                            Padding="12 6"
                            FontSize="12"
                            Cursor="Hand" />
                </StackPanel>
            </Border>

            <Border Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0 24 0 0">
                <StackPanel>
                    <TextBlock Text="ACCIONES RÁPIDAS" FontSize="11" Foreground="{DynamicResource TextDimBrush}" />
                    <ItemsControl ItemsSource="{Binding QuickActions}" Margin="0 12 0 0"
                                  x:Name="QuickActionsPresenter">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Nombre}"
                                        Command="{Binding DataContext.RunQuickActionCommand, Source={x:Reference QuickActionsPresenter}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        materialDesign:ButtonAssist.CornerRadius="4"
                                        Padding="14 7" Margin="0 0 8 8"
                                        FontSize="12" Cursor="Hand" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>