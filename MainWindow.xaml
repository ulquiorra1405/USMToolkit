<Window x:Class="Toolkit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:models="clr-namespace:Toolkit.Models"
        Title="Toolkit"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{DynamicResource ContentBgBrush}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        StateChanged="OnWindowStateChanged">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="4"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <materialDesign:DialogHost Identifier="RootDialog" Background="Transparent">
        <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{DynamicResource ContentBgBrush}"
                MouseDown="OnTitleBarMouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center"
                        Style="{StaticResource TitleBarIconButton}" Margin="4 0 0 0"
                        ToolTip="{Binding ToggleTooltip}"
                        Command="{Binding ToggleSidebarCommand}">
                    <materialDesign:PackIcon Kind="DockRight" Width="18" Height="18" Foreground="#888" />
                </Button>

                <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                      MaxWidth="480">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="{Binding ToolkitRootDisplay}"
                            Background="{DynamicResource SidebarBgBrush}" Foreground="#888" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Cursor="Hand" Padding="6 4" Margin="0 0 8 0"
                            FontSize="11" materialDesign:ButtonAssist.CornerRadius="4"
                            Command="{Binding ToggleToolkitRootCommand}"
                            ToolTip="Haz clic para alternar entre Local y Red" />

                    <Border Grid.Column="1" MaxWidth="360" Width="300">
                        <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Buscar comandos..."
                                 materialDesign:HintAssist.Foreground="{DynamicResource HintTextBrush}"
                                 materialDesign:TextFieldAssist.HasFilledTextField="True"
                                 materialDesign:TextFieldAssist.UnderlineBrush="{x:Null}"
                                 CaretBrush="#F5A623"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 FontSize="13"
                                 Padding="8 6"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"
                                 Background="{DynamicResource CardBgBrush}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                    </Border>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Stretch">
                    <Button x:Name="MinimizeBtn" Width="46"
                            Style="{StaticResource TitleBarButton}"
                            Click="OnMinimizeClick">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="12" Height="12" Foreground="#888" />
                    </Button>
                    <Button x:Name="MaximizeBtn" Width="46"
                            Style="{StaticResource TitleBarButton}"
                            Click="OnMaximizeRestoreClick">
                        <materialDesign:PackIcon x:Name="MaxIcon" Kind="WindowMaximize" Width="12" Height="12" Foreground="#888" />
                    </Button>
                    <Button x:Name="CloseBtn" Width="46"
                            Style="{StaticResource TitleBarCloseButton}"
                            Click="OnCloseClick">
                        <materialDesign:PackIcon Kind="WindowClose" Width="12" Height="12" Foreground="#888" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar -->
        <Border x:Name="SidebarPanel" Grid.Row="1" Grid.Column="0" Width="48"
                Background="Transparent" ClipToBounds="True">
            <StackPanel VerticalAlignment="Top" Margin="0 8 0 0">
                <Button MinHeight="36" Margin="0 2"
                        Command="{Binding NavigateCommand}" CommandParameter="0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarItemButton}">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="Width" Value="36" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                    <Setter Property="Width" Value="160" />
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Margin" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                        <Setter Property="Margin" Value="6 0 0 0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="Apps" Width="22" Height="22"
                                   HorizontalAlignment="Center"
                                   Foreground="{Binding SelectedIndex, Converter={StaticResource NavColorConverter}, ConverterParameter=0}" />
                        <TextBlock Grid.Column="1" Text="Dashboard" FontSize="13" Margin="8 0 0 0"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding SelectedIndex, Converter={StaticResource NavColorConverter}, ConverterParameter=0}"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Button>

                <Button MinHeight="36" Margin="0 2"
                        Command="{Binding ShowAllDeploymentsCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarItemButton}">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="Width" Value="36" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                    <Setter Property="Width" Value="160" />
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Margin" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                        <Setter Property="Margin" Value="6 0 0 0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="PackageVariantClosed" Width="22" Height="22"
                                   HorizontalAlignment="Center"
                                   Foreground="{Binding SelectedIndex, Converter={StaticResource NavColorConverter}, ConverterParameter=1}" />
                        <TextBlock Grid.Column="1" Text="Instalación" FontSize="13" Margin="8 0 0 0"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding SelectedIndex, Converter={StaticResource NavColorConverter}, ConverterParameter=1}"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Button>

                <StackPanel Visibility="{Binding HasSidebarCategories, Converter={StaticResource BoolToVis}}">
                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="12 8" />
                    <ItemsControl ItemsSource="{Binding SidebarCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:CategoriaItem}">
                                <Button MinHeight="36" Margin="0 2"
                                        Command="{Binding DataContext.NavigateToCategoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarItemButton}">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="Width" Value="36" />
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                    <Setter Property="Width" Value="160" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Margin" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                        <Setter Property="Margin" Value="6 0 0 0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0" Kind="{Binding Icono, Converter={StaticResource StringToIcon}}"
                                                                 Width="22" Height="22" HorizontalAlignment="Center">
                                            <materialDesign:PackIcon.Foreground>
                                                <MultiBinding Converter="{StaticResource CategorySelectedConverter}">
                                                    <Binding Path="DataContext.SelectedCategory" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                    <Binding />
                                                </MultiBinding>
                                            </materialDesign:PackIcon.Foreground>
                                        </materialDesign:PackIcon>
                                        <TextBlock Grid.Column="1" Text="{Binding Nombre}" FontSize="13" Margin="8 0 0 0"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding DataContext.IsSidebarExpanded, Converter={StaticResource BoolToVis}, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <TextBlock.Foreground>
                                                <MultiBinding Converter="{StaticResource CategorySelectedConverter}">
                                                    <Binding Path="DataContext.SelectedCategory" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                    <Binding />
                                                </MultiBinding>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Manuales -->
                <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="12 8" />

                <Button MinHeight="36" Margin="0 2"
                        Command="{Binding NavigateCommand}" CommandParameter="4">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarItemButton}">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="Width" Value="36" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                    <Setter Property="Width" Value="160" />
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Margin" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                        <Setter Property="Margin" Value="6 0 0 0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="BookOpenOutline" Width="22" Height="22"
                                   HorizontalAlignment="Center"
                                   Foreground="{Binding SelectedIndex, Converter={StaticResource NavColorConverter}, ConverterParameter=4}" />
                        <TextBlock Grid.Column="1" Text="Manuales" FontSize="13" Margin="8 0 0 0"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding SelectedIndex, Converter={StaticResource NavColorConverter}, ConverterParameter=4}"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Button>

                <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="12 8" />

                <Button MinHeight="36" Margin="0 2"
                        Command="{Binding NavigateCommand}" CommandParameter="2">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarItemButton}">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="Width" Value="36" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                    <Setter Property="Width" Value="160" />
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Margin" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                        <Setter Property="Margin" Value="6 0 0 0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="PencilOutline" Width="22" Height="22"
                                   HorizontalAlignment="Center"
                                   Foreground="{Binding SelectedIndex, Converter={StaticResource NavColorConverter}, ConverterParameter=2}" />
                        <TextBlock Grid.Column="1" Text="Editor" FontSize="13" Margin="8 0 0 0"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding SelectedIndex, Converter={StaticResource NavColorConverter}, ConverterParameter=2}"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Button>

                <Button MinHeight="36" Margin="0 2"
                        Command="{Binding NavigateCommand}" CommandParameter="3">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarItemButton}">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="Width" Value="36" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                    <Setter Property="Width" Value="160" />
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Margin" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                        <Setter Property="Margin" Value="6 0 0 0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="SettingsOutline" Width="22" Height="22"
                                   HorizontalAlignment="Center"
                                   Foreground="{Binding SelectedIndex, Converter={StaticResource NavColorConverter}, ConverterParameter=3}" />
                        <TextBlock Grid.Column="1" Text="Ajustes" FontSize="13" Margin="8 0 0 0"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding SelectedIndex, Converter={StaticResource NavColorConverter}, ConverterParameter=3}"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,1,0,0" CornerRadius="20,0,0,0"
                Background="{DynamicResource ContentBgBrush}" ClipToBounds="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" MinWidth="100" />
                    <ColumnDefinition Width="{Binding HasLogPanel, Converter={StaticResource SplitterWidthConverter}}" MinWidth="0" />
                    <ColumnDefinition Width="{Binding HasLogPanel, Converter={StaticResource DescColWidthConverter}}" MinWidth="0" />
                </Grid.ColumnDefinitions>

                <ContentControl Grid.Column="0" Content="{Binding CurrentPage}" Margin="24" />

                <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}" Width="1" HorizontalAlignment="Center"
                           Visibility="{Binding HasLogPanel, Converter={StaticResource BoolToVis}}" />
                <GridSplitter Grid.Column="1"
                              Width="5"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              BorderThickness="0"
                              ShowsPreview="False"
                              Cursor="SizeWE"
                              Visibility="{Binding HasLogPanel, Converter={StaticResource BoolToVis}}">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Setter Property="Background" Value="Transparent" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#18FFFFFF" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </GridSplitter.Style>
                </GridSplitter>

                <Border Grid.Column="2"
                        Background="{DynamicResource ContentBgBrush}" ClipToBounds="True"
                        Visibility="{Binding HasLogPanel, Converter={StaticResource BoolToVis}}">
                    <Grid Margin="24 24 24 24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="SALIDA" FontSize="11" Foreground="{DynamicResource TextDimBrush}" Margin="0 0 0 12" />

                        <Border x:Name="LogBorder" Grid.Row="1" BorderBrush="{DynamicResource SidebarBgBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Background="{DynamicResource DarkCardBgBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ScrollViewer Grid.Row="0" x:Name="LogScrollViewer"
                                              VerticalScrollBarVisibility="Visible"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <Grid>
                                        <TextBlock Text="{Binding Deployments.LogOutput}" FontFamily="Consolas"
                                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                   Visibility="{Binding IsDeploymentsView, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding Ejecuciones.LogOutput}" FontFamily="Consolas"
                                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                   Visibility="{Binding IsEjecucionesView, Converter={StaticResource BoolToVis}}" />
                                    </Grid>
                                </ScrollViewer>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 8 0 0">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsDeploymentsView, Converter={StaticResource BoolToVis}}">
                                            <Button Content="⛔ Detener proceso"
                                                    Command="{Binding Deployments.InterruptCommand}"
                                                    Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="4"
                                                    Padding="14 7" FontSize="12" Cursor="Hand" MaxHeight="30" />
                                            <Button Content="🗑 Limpiar log"
                                                    Command="{Binding Deployments.ClearLogCommand}"
                                                    Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="4"
                                                    Padding="14 7" FontSize="12" Cursor="Hand" MaxHeight="30" Margin="8 0 0 0" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsEjecucionesView, Converter={StaticResource BoolToVis}}">
                                            <Button Content="⛔ Detener proceso"
                                                    Command="{Binding Ejecuciones.InterruptCommand}"
                                                    Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="4"
                                                    Padding="14 7" FontSize="12" Cursor="Hand" MaxHeight="30" />
                                            <Button Content="🗑 Limpiar log"
                                                    Command="{Binding Ejecuciones.ClearLogCommand}"
                                                    Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="4"
                                                    Padding="14 7" FontSize="12" Cursor="Hand" MaxHeight="30" Margin="8 0 0 0" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Progress Snackbar (overlay over everything) -->
        <Border x:Name="ProgressSnackbar" Grid.RowSpan="2" Grid.ColumnSpan="2"
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0 0 0 48"
                Background="{DynamicResource SidebarBgBrush}" BorderBrush="{DynamicResource TextMutedBrush}" BorderThickness="1"
                CornerRadius="8" Padding="20 14"
                Opacity="0"
                Panel.ZIndex="100">
            <Grid>
                <StackPanel Orientation="Horizontal" MinWidth="320"
                            Visibility="{Binding IsDeploymentsView, Converter={StaticResource BoolToVis}}">
                    <ProgressBar Width="100" Height="4" VerticalAlignment="Center" Margin="0 0 12 0"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding Deployments.ProgressPercent, Mode=OneWay}"
                                 Foreground="#F5A623" Background="{DynamicResource TextDimBrush}" />
                    <TextBlock Text="{Binding Deployments.ProgressMessage}" FontSize="13"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" MinWidth="320"
                            Visibility="{Binding IsEjecucionesView, Converter={StaticResource BoolToVis}}">
                    <ProgressBar Width="100" Height="4" VerticalAlignment="Center" Margin="0 0 12 0"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding Ejecuciones.ProgressPercent, Mode=OneWay}"
                                 Foreground="#F5A623" Background="{DynamicResource TextDimBrush}" />
                    <TextBlock Text="{Binding Ejecuciones.ProgressMessage}" FontSize="13"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>
        </Grid>
    </materialDesign:DialogHost>
</Window>
